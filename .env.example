# ══════════════════════════════════════════════════════════════════════════════
#  UrivDocs — Environment Variables Template
#
#  INSTRUCTIONS:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in your values below
#    3. NEVER commit .env to git (it's in .gitignore)
#
#  For production: these values are injected automatically by GitHub Actions
#  from your GitHub Secrets. You only need this file for local development.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Settings ──────────────────────────────────────────────────────────────
LLM_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=/app/storage/vectordb

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_MB=2048

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=256
CHUNK_OVERLAP=32

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
MIN_SCORE=0.15

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
# For local dev:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# For production (set EC2_HOST and DOMAIN_NAME in GitHub Secrets):
# CORS_ORIGINS=http://YOUR_EC2_IP,https://yourdomain.com

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Create an IAM user with S3 permissions — DO NOT use root credentials
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
S3_BUCKET=urivdocs-uploads-yourname
